# ── Base de datos ─────────────────────────────────────────────────────────────
# MongoDB Atlas → Connect → Drivers → copia la URI y reemplaza <password>
MONGO_URI=mongodb+srv://usuario:PASSWORD@cluster0.xxxxx.mongodb.net/dulce-vanidad?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera un secreto seguro con:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=pon_aqui_un_string_muy_largo_y_aleatorio
JWT_EXPIRES_IN=7d

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS (URL de tu frontend en Vercel, sin barra al final) ───────────────────
FRONTEND_URL=https://dulce-vanidad.vercel.app
